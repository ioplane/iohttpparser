# clang-tidy configuration for iohttpparser
# Security-critical static analysis for C23 HTTP parser library
# Dual-compiler strategy: clang-tidy (primary) + GCC -fanalyzer (validation)

---
Checks: >
  clang-diagnostic-*,
  clang-analyzer-*,
  clang-analyzer-security.*,
  clang-analyzer-unix.*,
  clang-analyzer-deadcode.*,
  clang-analyzer-core.*,
  bugprone-*,
  cert-*,
  concurrency-*,
  misc-*,
  performance-*,
  portability-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -modernize-use-trailing-return-type,
  -readability-function-cognitive-complexity,
  -readability-identifier-length,
  -readability-magic-numbers,
  -misc-no-recursion

# Security-critical checks treated as errors
WarningsAsErrors: >
  clang-analyzer-security.*,
  clang-analyzer-core.NullDereference,
  clang-analyzer-core.UndefinedBinaryOperatorResult,
  clang-analyzer-unix.Malloc,
  clang-analyzer-unix.MallocSizeof,
  bugprone-use-after-move,
  bugprone-double-free,
  bugprone-sizeof-expression,
  bugprone-string-constructor,
  bugprone-suspicious-memory-comparison,
  bugprone-signal-handler,
  cert-err34-c,
  cert-msc30-c,
  cert-msc50-cpp

HeaderFilterRegex: 'src/.*'

FormatStyle: file

CheckOptions:
  # Naming conventions (snake_case for C)
  - key: readability-identifier-naming.FunctionCase
    value: lower_case
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key: readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.StructCase
    value: lower_case
  - key: readability-identifier-naming.TypedefSuffix
    value: _t
  - key: readability-identifier-naming.GlobalConstantCase
    value: UPPER_CASE

  # Braces required on ALL statements (security: prevent goto-fail bugs)
  - key: readability-braces-around-statements.ShortStatementLines
    value: '0'

  # Function size limits
  - key: readability-function-size.LineThreshold
    value: '200'
  - key: readability-function-size.StatementThreshold
    value: '100'
  - key: readability-function-size.ParameterThreshold
    value: '8'
  - key: readability-function-size.NestingThreshold
    value: '6'

  # Suspicious sizeof patterns (critical for network parsing)
  - key: bugprone-sizeof-expression.WarnOnSizeOfPointer
    value: '1'
