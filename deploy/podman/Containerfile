FROM oraclelinux:10

LABEL maintainer="iohttpparser development team"
LABEL description="Development environment for iohttpparser — C23 HTTP/1.1 parser with SIMD acceleration"

# Build arguments for tool versions
ARG CMAKE_VERSION=4.2.3
ARG CLANG_VERSION=22.1.0
ARG DOXYGEN_VERSION=1.16.1
ARG UNITY_VERSION=2.6.1

# Enable CodeReady Builder repo (for -devel packages not in baseos/appstream)
RUN dnf install -y oraclelinux-developer-release-el10 && \
    dnf config-manager --set-enabled ol10_codeready_builder && \
    dnf clean all

# Install base development tools (system gcc needed for libraries that build with default cc)
RUN dnf install -y \
    gcc \
    gcc-c++ \
    make \
    autoconf \
    automake \
    libtool \
    pkgconfig \
    openssl-devel \
    git \
    vim \
    gdb \
    valgrind \
    strace \
    wget \
    curl \
    tar \
    xz \
    bzip2 \
    patch \
    flex \
    bison \
    && dnf clean all

# ═══════════════════════════════════════════════════════
# Compilers (from source / pre-built)
# ═══════════════════════════════════════════════════════

# Install Clang 22.1.0 from pre-built release binary (selective — only needed tools)
RUN cd /tmp && \
    curl -fsSL -o llvm.tar.xz \
        https://github.com/llvm/llvm-project/releases/download/llvmorg-${CLANG_VERSION}/LLVM-${CLANG_VERSION}-Linux-X64.tar.xz && \
    tar xJf llvm.tar.xz && \
    LLVM_DIR=LLVM-${CLANG_VERSION}-Linux-X64 && \
    CLANG_MAJOR=$(echo ${CLANG_VERSION} | cut -d. -f1) && \
    for tool in clang clang++ clang-cl clang-cpp clang-${CLANG_MAJOR} \
                clang-format clang-tidy clang-apply-replacements \
                clang-rename clang-check \
                lld ld.lld ld64.lld wasm-ld \
                llvm-ar llvm-nm llvm-objdump llvm-ranlib llvm-strip \
                llvm-symbolizer llvm-profdata llvm-cov llvm-objcopy \
                llvm-readelf llvm-size llvm-strings llvm-addr2line \
                scan-build scan-view; do \
        [ -e "$LLVM_DIR/bin/$tool" ] && cp -a "$LLVM_DIR/bin/$tool" /usr/local/bin/; \
    done && \
    cp -a $LLVM_DIR/lib/clang /usr/local/lib/ && \
    rm -rf /tmp/LLVM-* /tmp/llvm.tar.xz && \
    ldconfig && \
    clang --version

# Install GCC 15 from gcc-toolset-15 (OL10 appstream, pre-built)
RUN dnf install -y \
        gcc-toolset-15-gcc \
        gcc-toolset-15-gcc-c++ \
        gcc-toolset-15-libatomic-devel \
        gcc-toolset-15-libasan-devel \
        gcc-toolset-15-libubsan-devel \
        gcc-toolset-15-libtsan-devel \
        gcc-toolset-15-binutils \
    && dnf clean all && \
    ln -sf /opt/rh/gcc-toolset-15/root/usr/bin/gcc /usr/local/bin/gcc-15 && \
    ln -sf /opt/rh/gcc-toolset-15/root/usr/bin/g++ /usr/local/bin/g++-15 && \
    gcc-15 --version

# Install code quality and documentation tools
RUN dnf install -y \
    graphviz \
    python3 \
    python3-pip \
    && dnf clean all

# Install ninja, flawfinder, gcovr from PyPI
RUN pip3 install ninja flawfinder gcovr

# Build and install CMake from source
RUN cd /tmp && \
    wget https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}.tar.gz && \
    tar xzf cmake-${CMAKE_VERSION}.tar.gz && \
    cd cmake-${CMAKE_VERSION} && \
    ./bootstrap --prefix=/usr/local --parallel=$(nproc) && \
    make -j$(nproc) && \
    make install && \
    cd /tmp && rm -rf cmake-*

# Build and install cppcheck from source
RUN cd /tmp && \
    git clone --depth 1 --branch 2.20.0 https://github.com/danmar/cppcheck.git && \
    cd cppcheck && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local && \
    make -j$(nproc) && \
    make install && \
    cd /tmp && rm -rf cppcheck

# Build and install Doxygen from source
RUN cd /tmp && \
    wget https://github.com/doxygen/doxygen/archive/refs/tags/Release_${DOXYGEN_VERSION//./_}.tar.gz && \
    tar xzf Release_${DOXYGEN_VERSION//./_}.tar.gz && \
    cd doxygen-Release_${DOXYGEN_VERSION//./_} && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local && \
    make -j$(nproc) && \
    make install && \
    cd /tmp && rm -rf doxygen-* Release_*

# Install Unity testing framework
RUN cd /tmp && \
    wget https://github.com/ThrowTheSwitch/Unity/archive/refs/tags/v${UNITY_VERSION}.tar.gz && \
    tar xzf v${UNITY_VERSION}.tar.gz && \
    cd Unity-${UNITY_VERSION} && \
    mkdir -p /usr/local/include/unity && \
    mkdir -p /usr/local/src/unity && \
    cp src/unity.h src/unity_internals.h /usr/local/include/unity/ && \
    cp src/unity.c /usr/local/src/unity/ && \
    cd /tmp && rm -rf Unity-* v${UNITY_VERSION}.tar.gz

# ═══════════════════════════════════════════════════════
# Linker: mold (fast debug builds)
# ═══════════════════════════════════════════════════════

RUN cd /tmp && \
    git clone --depth 1 --branch v2.40.4 https://github.com/rui314/mold.git && \
    cd mold && \
    mkdir build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local && \
    make -j$(nproc) && \
    make install && \
    cd /tmp && rm -rf mold

# ═══════════════════════════════════════════════════════
# Static Analysis
# ═══════════════════════════════════════════════════════

# PVS-Studio (license loaded from .env at runtime, not baked into image)
RUN wget -qO /etc/yum.repos.d/viva64.repo https://cdn.pvs-studio.ru/etc/viva64.repo && \
    dnf install -y pvs-studio && \
    dnf clean all

# CodeChecker (Ericsson, wraps Clang SA + clang-tidy + cppcheck)
RUN pip3 install codechecker && \
    ln -sf /usr/local/bin/CodeChecker /usr/local/bin/codechecker 2>/dev/null || true

# Update ldconfig cache
RUN ldconfig

CMD ["/bin/bash"]
