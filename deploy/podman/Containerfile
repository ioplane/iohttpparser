# iohttpparser development image
# Thin layer on top of the shared ioplane-base image.
#
# Build base first:
#   podman build -t ioplane-base:latest \
#     -f /opt/projects/repositories/container-images/tools/ioplane-base/Containerfile .
#
# Build this image:
#   podman build -t iohttpparser-dev:latest -f deploy/podman/Containerfile .

FROM localhost/ioplane-base:latest

LABEL maintainer="iohttpparser development team"
LABEL description="Development environment for iohttpparser — C23 HTTP/1.1 parser with SIMD acceleration"

# No project-specific dependencies — iohttpparser is a pure parser library.

WORKDIR /workspace
CMD ["/bin/bash"]
